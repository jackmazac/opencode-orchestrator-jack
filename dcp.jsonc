{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "experimental": {
    "allowSubAgents": true,
    "customPrompts": true
  },
  "turnProtection": {
    "enabled": true,
    "turns": 6
  },
  "compress": {
    "mode": "range",
    "permission": "allow",
    "protectUserMessages": true,
    "protectedTools": ["task", "skill", "todowrite", "todoread"],
    "nudgeForce": "soft",
    "nudgeFrequency": 8,
    "iterationNudgeThreshold": 20,
    "summaryBuffer": true,
    "minContextLimit": "30%",
    "maxContextLimit": "60%"
  }
}
