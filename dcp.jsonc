{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "experimental": {
    "allowSubAgents": true,
    "customPrompts": true
  },
  "compress": {
    "mode": "range",
    "permission": "allow",
    "protectUserMessages": true,
    "nudgeForce": "strong",
    "nudgeFrequency": 3,
    "iterationNudgeThreshold": 10,
    "summaryBuffer": true,
    "modelMaxLimits": {
      "amazon-bedrock/anthropic.claude-opus-4-6-v1-1m": "60%",
      "amazon-bedrock/anthropic.claude-opus-4-7-1m": "60%",
      "amazon-bedrock/anthropic.claude-sonnet-4-6-1m": "60%"
    },
    "modelMinLimits": {
      "amazon-bedrock/anthropic.claude-opus-4-6-v1-1m": "35%",
      "amazon-bedrock/anthropic.claude-opus-4-7-1m": "35%",
      "amazon-bedrock/anthropic.claude-sonnet-4-6-1m": "35%"
    }
  }
}
