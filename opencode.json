{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "@nick-vi/opencode-type-inject",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "instructions": ["./plugin/shell-strategy/shell_strategy.md"],
  "formatter": {
    "biome": {
      "disabled": true
    },
    "oxfmt": {
      "command": ["bun", "x", "oxfmt", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx"]
    }
  },
  "lsp": {
    "oxlint": {
      "command": ["bun", "x", "oxlint", "--lsp"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts", ".vue", ".astro", ".svelte"]
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "family": "gpt",
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "release_date": "2026-03-05",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        }
      }
    },
    "google": {
    }
  },
  "agent": {
    "orchestrator": {
      "description": "Primary agent that plans, ideates, delegates, and synthesizes — Claude Sonnet 4.6 1m",
      "mode": "primary",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6-1m",
      "reasoningEffort": "max",
      "prompt": "{file:./prompts/orchestrator.txt}",
      "permission": {
        "task": {
          "planner": "allow",
          "executor-genius": "allow",
          "executor-high": "allow",
          "executor-medium": "allow",
          "executor-low": "allow",
          "suborchestrator": "allow",
          "explore": "allow",
          "explore-high": "allow",
          "reviewer": "allow",
          "designer": "allow",
          "debugger-xhigh": "allow",
          "validator": "allow",
          "deployer": "allow",
          "scribe": "allow",
          "brainstormer": "allow"
        }
      }
    },
    "compaction": {
      "prompt": "{file:./prompts/compaction.txt}"
    },
    "planner": {
      "description": "Drafts implementation plans with complexity assessments. Can explore the codebase — GPT-5.4 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/planner.txt}",
      "tools": { "write": false, "edit": false, "bash": true },
      "permission": {
        "task": {
          "explore": "allow",
          "explore-high": "allow"
        }
      }
    },
    "debugger-xhigh": {
      "description": "High-complexity code debugging — GPT-5.4 with xhigh reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/debugger.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "executor-genius": {
      "description": "Highest-complexity code execution — Claude Opus 4.6 1m with high reasoning",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-opus-4-6-v1-1m",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-high": {
      "description": "High-complexity code execution — GPT-5.4 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-medium": {
      "description": "Medium-complexity code execution — Claude Sonnet 4.6 1m",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6-1m",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-low": {
      "description": "Low-complexity code execution — Gemini 3.1 Pro with high reasoning",
      "mode": "subagent",
      "model": "google/gemini-3.1-pro-preview",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "suborchestrator": {
      "description": "Manages focused multi-file campaigns — lint fixes, mechanical refactors, migrations — Claude Sonnet 4.6 1m with max reasoning",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6-1m",
      "reasoningEffort": "max",
      "prompt": "{file:./prompts/suborchestrator.txt}",
      "tools": { "write": false, "edit": false, "bash": true },
      "permission": {
        "task": {
          "executor-medium": "allow",
          "executor-low": "allow",
          "explore": "allow"
        }
      }
    },
    "reviewer": {
      "description": "Reviews executor output, runs tests, validates against plan — GPT-5.4 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/reviewer.txt}",
      "tools": { "write": false, "edit": false, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "explore": {
      "description": "Fast, read-only agent for exploring codebases — Gemini 3 Flash",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/explore.txt}",
      "tools": { "write": false, "edit": false, "bash": true }
    },
    "explore-high": {
      "description": "Deep codebase exploration for complex analysis — GPT-5.4 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/explore.txt}",
      "tools": { "write": false, "edit": false, "bash": true }
    },
    "designer": {
      "description": "UI/UX design specialist — generates design systems and implements UI code using ui-ux-pro-max skill — Claude Sonnet 4.6 1m",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6-1m",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/designer.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "validator": {
      "description": "Runs full project check suite, triages failures, fixes mechanical issues — Gemini 3.1 Pro with high reasoning",
      "mode": "subagent",
      "model": "google/gemini-3.1-pro-preview",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/validator.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "deployer": {
      "description": "Gate-based deployment workflows with safety verification — GPT-5.4 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/deployer.txt}",
      "tools": { "write": true, "edit": false, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "scribe": {
      "description": "Documentation agent — codifies patterns, conventions, and rules from completed work — Claude Sonnet 4.6 1m with high reasoning",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6-1m",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/scribe.txt}",
      "tools": { "write": true, "edit": true, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "brainstormer": {
      "description": "Explores problem spaces, generates approaches with tradeoffs, recommends direction — Gemini 3.1 Pro",
      "mode": "subagent",
      "model": "google/gemini-3.1-pro-preview",
      "prompt": "{file:./prompts/brainstormer.txt}",
      "reasoningEffort": "high",
      "tools": { "write": false, "edit": false, "bash": true },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "ccapi": {
      "type": "local",
      "command": ["uvx", "--with", "botocore[crt]", "awslabs.ccapi-mcp-server@latest"],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "cloudwatch": {
      "type": "local",
      "command": ["uvx", "--with", "botocore[crt]", "awslabs.cloudwatch-mcp-server@latest"],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "cloudtrail": {
      "type": "local",
      "command": ["uvx", "--with", "botocore[crt]", "awslabs.cloudtrail-mcp-server@latest"],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "git-research": {
      "type": "local",
      "command": ["uvx", "awslabs.git-repo-research-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "doc-loader": {
      "type": "local",
      "command": ["uvx", "awslabs.document-loader-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "aws-iac": {
      "type": "local",
      "command": ["uvx", "--with", "botocore[crt]", "awslabs.aws-iac-mcp-server@latest"],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}"
    }
  }
}
