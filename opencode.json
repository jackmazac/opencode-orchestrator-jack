{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "reserved": 160000
  },
  "plugin": [
    "@nick-vi/opencode-type-inject",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "instructions": [
    "./plugin/shell-strategy/shell_strategy.md"
  ],
  "formatter": {
    "biome": {
      "disabled": true
    },
    "oxfmt": {
      "command": [
        "bun",
        "x",
        "oxfmt",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ]
    }
  },
  "lsp": {
    "biome": {
      "disabled": true
    },
    "oxlint": {
      "command": [
        "bun",
        "x",
        "oxlint",
        "--lsp"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
        ".vue",
        ".astro",
        ".svelte"
      ]
    }
  },
  "agent": {
    "orchestrator": {
      "description": "Primary agent that plans, ideates, delegates, and synthesizes — Claude Opus 4.7 1m",
      "mode": "primary",
      "model": "amazon-bedrock/anthropic.claude-opus-4-7",
      "reasoningEffort": "max",
      "prompt": "{file:./prompts/orchestrator.txt}",
      "permission": {
        "task": {
          "planner": "allow",
          "executor-genius": "allow",
          "executor-high": "allow",
          "executor-medium": "allow",
          "executor-low": "allow",
          "suborchestrator": "allow",
          "explore": "allow",
          "explore-high": "allow",
          "reviewer": "allow",
          "designer": "allow",
          "debugger-xhigh": "allow",
          "validator": "allow",
          "deployer": "allow",
          "scribe": "allow",
          "brainstormer": "allow"
        }
      }
    },
    "compaction": {
      "prompt": "{file:./prompts/compaction.txt}"
    },
    "planner": {
      "description": "Drafts implementation plans with complexity assessments. Can explore the codebase — GPT-5.5 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/planner.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow",
          "explore-high": "allow"
        }
      }
    },
    "debugger-xhigh": {
      "description": "High-complexity code debugging — GPT-5.5 with xhigh reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/debugger.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "executor-genius": {
      "description": "Highest-complexity code execution — Claude Opus 4.7 1m with high reasoning",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-opus-4-7",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-high": {
      "description": "High-complexity code execution — GPT-5.5 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-medium": {
      "description": "Medium-complexity code execution — Claude Sonnet 4.6 1m",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "executor-low": {
      "description": "Low-complexity code execution — GPT-5.5 with low reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "suborchestrator": {
      "description": "Manages focused multi-file campaigns — lint fixes, mechanical refactors, migrations — Claude Sonnet 4.6 1m with max reasoning",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6",
      "reasoningEffort": "max",
      "prompt": "{file:./prompts/suborchestrator.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "executor-medium": "allow",
          "executor-low": "allow",
          "explore": "allow"
        }
      }
    },
    "reviewer": {
      "description": "Reviews executor output, runs tests, validates against plan — GPT-5.5 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/reviewer.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "explore": {
      "description": "Fast, read-only agent for exploring codebases — GPT-5.5 with low reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "prompt": "{file:./prompts/explore.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "explore-high": {
      "description": "Deep codebase exploration for complex analysis — GPT-5.5 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/explore.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "designer": {
      "description": "UI/UX design specialist — generates design systems and implements UI code using ui-ux-pro-max skill — Claude Sonnet 4.6 1m",
      "mode": "subagent",
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/designer.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "validator": {
      "description": "Runs full project check suite, triages failures, fixes mechanical issues — GPT-5.5 with medium reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/validator.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "deployer": {
      "description": "Gate-based deployment workflows with safety verification — GPT-5.5 with high reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:./prompts/deployer.txt}",
      "tools": {
        "write": true,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "scribe": {
      "description": "Documentation agent — codifies patterns, conventions, and rules from completed work — GPT-5.5 with medium reasoning",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/scribe.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    },
    "brainstormer": {
      "description": "Explores problem spaces, generates approaches with tradeoffs, recommends direction — Gemini 3.1 Pro",
      "mode": "subagent",
      "model": "google/gemini-3.1-pro-preview",
      "prompt": "{file:./prompts/brainstormer.txt}",
      "reasoningEffort": "high",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "explore": "allow"
        }
      }
    }
  },
  "mcp": {
    "doc-loader": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.document-loader-mcp-server@latest"
      ],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "cloudwatch": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.cloudwatch-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "aws-iac": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.aws-iac-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "bedrock-kb-retrieval": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.bedrock-kb-retrieval-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "ccapi": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.ccapi-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "chrome_devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "git-research": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.git-repo-research-mcp-server@latest"
      ],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}"
    },
    "ecs": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.ecs-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "cloudtrail": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.cloudtrail-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default"
      }
    },
    "bedrock-agentcore": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "botocore[crt]",
        "awslabs.amazon-bedrock-agentcore-mcp-server@latest"
      ],
      "environment": {
        "AWS_REGION": "us-west-2",
        "AWS_PROFILE": "default",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "vibe_kanban": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "vibe-kanban@latest",
        "--mcp"
      ],
      "enabled": true
    },
    "motif": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "/Users/jack.mazac/Developer/execintel/tools/mcp-bridge/src/index.ts"
      ],
      "environment": {
        "MCP_TARGET_URL": "https://dev.motif.fox/api/mcp",
        "MCP_AUTH_MODE": "e2e",
        "E2E_AUTH_SECRET": "{env:E2E_AUTH_SECRET}"
      }
    }
  }
}
